# ---------- Sensitive (keep in .env only, never commit) ----------
# Gmail OAuth – from Google Cloud Console → Credentials → your OAuth 2.0 Client ID
GMAIL_CLIENT_ID=your_client_id.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=your_client_secret

# Optional: path for OAuth token file (default: backend/token.json). Token file is gitignored.
# GMAIL_TOKEN_PATH=token.json

# Assistant – Hugging Face (optional; if unset, assistant is disabled)
# Create a token with "Make calls to Inference Providers" at:
# https://huggingface.co/settings/tokens/new?ownUserPermissions=inference.serverless.write&tokenType=fineGrained
# HF_API_TOKEN=hf_...
# Optional: model id for HF router serverless (default: meta-llama/Llama-3.2-3B-Instruct)
# HF_MODEL_ID=meta-llama/Llama-3.2-3B-Instruct
# LLM_TIMEOUT_SEC=60

# ---------- Server (optional overrides) ----------
HOST=0.0.0.0
PORT_HTTP=8000
PORT_GRPC=50051

# Logging (default INFO)
# LOG_LEVEL=DEBUG
